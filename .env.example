# Copiar para .env e ajustar aos valores locais.
# Atenção: variáveis VITE_* são embebidas no bundle do cliente e ficam
# visíveis publicamente. Nunca colocar segredos aqui.

VITE_API_URL=http://localhost:8000/api/v1

# Servidor TURN usado pelo player WHEP (src/components/live/useWhepPlayer.ts).
# Se ficarem vazias, é usado o servidor público openrelay por omissão.
VITE_TURN_URL=
VITE_TURN_USERNAME=
VITE_TURN_CREDENTIAL=
